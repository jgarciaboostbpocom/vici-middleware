# Staging/test Vicidial environment template.
# Example only. Do not place real secrets in this file.
# Do not copy this into production without replacing every placeholder.

NODE_ENV=production
PORT=3000

# Vicidial staging/test.
# Use VICI_MODE=mock for local-only testing; use real when validating against staging Vicidial DB.
VICI_MODE=real
VICI_URL=https://<staging-vicidial-host>/vicidial
VICI_USER=<staging-vicidial-api-user>
VICI_PASS=<staging-vicidial-api-password>
VICI_DB_HOST=<staging-vicidial-db-host>
VICI_DB_PORT=3306
VICI_DB_USER=<staging-read-or-service-user>
VICI_DB_PASS=<staging-password>
VICI_DB_NAME=asterisk
CAMPAIGN_ID=<staging-campaign-id>

# Middleware local services and defaults.
REDIS_URL=redis://127.0.0.1:6379
CALLS_PER_DID=70
CALLS_PER_DID_HOURLY=20
AHT_MIN_SECONDS=90
VM_MIN_SECONDS=105
DID_POOL=
VICI_MW_SESSION_TTL_HOURS=12
ADMIN_TOKEN=<staging-admin-token>

# Route engine: staging should remain shadow unless explicitly testing disabled/fallback behavior.
ROUTE_ENGINE_MODE=shadow
ROUTE_ENGINE_TOKEN=<staging-route-token>
ROUTE_ENGINE_ALLOW_UNSCOPED_DID_FALLBACK=false
ROUTE_ENGINE_ALLOW_CLIENT_DID_FALLBACK=true
ROUTE_ENGINE_REQUIRE_CAMPAIGN_MATCH=false
ROUTE_ENGINE_DEFAULT_HUMAN_QUEUE=HUMAN_QUEUE

# Route durable storage. Prefer a route-engine DB/schema or staging-safe tables.
ROUTE_DB_HOST=<staging-route-db-host-or-same-db>
ROUTE_DB_PORT=3306
ROUTE_DB_USER=<staging-route-db-user>
ROUTE_DB_PASS=<staging-route-db-password>
ROUTE_DB_NAME=<route-engine-db-name>

# DID selector observation flags.
DID_SELECTION_V2_ENABLED=false
DID_SELECTION_V2_DRY_RUN=true
DID_SELECTION_V2_PERSIST_OBSERVATIONS=false
