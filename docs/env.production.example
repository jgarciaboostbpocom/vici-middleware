# Production Vicidial environment template.
# Example only. Do not commit real secrets.
# Production must start in ROUTE_ENGINE_MODE=shadow.
# Do not enable live mode until AGI/FastAGI testing, durable schema, fallback,
# timeout behavior, and campaign/DID mapping are verified.

NODE_ENV=production
PORT=3000

# Vicidial production.
VICI_MODE=real
VICI_URL=https://<production-vicidial-host>/vicidial
VICI_USER=<production-vicidial-api-user>
VICI_PASS=<production-vicidial-api-password>
VICI_DB_HOST=<production-vicidial-db-host>
VICI_DB_PORT=3306
VICI_DB_USER=<production-service-user>
VICI_DB_PASS=<production-password>
VICI_DB_NAME=asterisk
CAMPAIGN_ID=<production-campaign-id>

# Middleware local services and defaults.
REDIS_URL=redis://<production-redis-host>:6379
CALLS_PER_DID=70
CALLS_PER_DID_HOURLY=20
AHT_MIN_SECONDS=90
VM_MIN_SECONDS=105
DID_POOL=
VICI_MW_SESSION_TTL_HOURS=12
ADMIN_TOKEN=<production-admin-token>

# Route engine: production starts in shadow only.
ROUTE_ENGINE_MODE=shadow
ROUTE_ENGINE_TOKEN=<production-route-token>
ROUTE_ENGINE_ALLOW_UNSCOPED_DID_FALLBACK=false
ROUTE_ENGINE_ALLOW_CLIENT_DID_FALLBACK=true
ROUTE_ENGINE_REQUIRE_CAMPAIGN_MATCH=false
ROUTE_ENGINE_DEFAULT_HUMAN_QUEUE=HUMAN_QUEUE

# Route durable storage. Prefer separate production route DB/schema.
ROUTE_DB_HOST=<production-route-db-host>
ROUTE_DB_PORT=3306
ROUTE_DB_USER=<production-route-db-user>
ROUTE_DB_PASS=<production-route-db-password>
ROUTE_DB_NAME=<route-engine-db-name>

# DID selector observation flags. Keep conservative at production start.
DID_SELECTION_V2_ENABLED=false
DID_SELECTION_V2_DRY_RUN=true
DID_SELECTION_V2_PERSIST_OBSERVATIONS=false
